{
  "name": "malkiat-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build && tsgo -p tsconfig.tsgo.json --noEmit",
    "tsgo": "tsgo",
    "typecheck": "tsgo -p tsconfig.tsgo.json --noEmit",
    "format": "oxfmt write src test scripts",
    "start": "nest start",
    "start:api:dev": "nest start --watch",
    "start:dev": "tsgo -p tsconfig.tsgo.json --noEmit & nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "start:worker:dev": "ts-node -r tsconfig-paths/register src/worker-main.ts",
    "start:worker": "node dist/src/worker-main.js",
    "lint": "oxlint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:clean": "rm -rf ./src/infrastructure/db/drizzle/migrations/*",
    "typesense:collection:listings": "node scripts/typesense/create-listings-collection.ts",
    "typesense:backfill:listings": "node scripts/typesense/backfill-listings.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/cqrs": "^11.0.0",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.5",
    "@thallesp/nestjs-better-auth": "^2.2.2",
    "@vercel/blob": "^2.0.1",
    "better-auth": "^1.4.17",
    "bullmq": "^5.41.0",
    "drizzle-orm": "^0.44.0",
    "drizzle-zod": "^0.8.3",
    "ioredis": "^5.9.2",
    "nest-winston": "^1.10.2",
    "postgres": "^3.4.7",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.8.0",
    "rxjs": "^7.8.1",
    "typesense": "^2.1.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "@typescript/native-preview": "^7.0.0-dev.20260123.3",
    "drizzle-kit": "^0.31.4",
    "jest": "^30.0.0",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/test/unit"
    ],
    "moduleNameMapper": {
      "^@app/(.*)$": "<rootDir>/src/app/$1",
      "^@shared/(.*)$": "<rootDir>/src/shared/$1",
      "^@infra/(.*)$": "<rootDir>/src/infrastructure/$1",
      "^@modules/(.*)$": "<rootDir>/src/modules/$1",
      "^@worker/(.*)$": "<rootDir>/src/worker/$1",
      "^@test/(.*)$": "<rootDir>/test/$1"
    }
  }
}
