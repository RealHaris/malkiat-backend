PORT=3000
NODE_ENV=development

# Logging
LOG_LEVEL=info
LOG_DIR=logs
LOG_MAX_FILES=3d
LOG_MAX_SIZE=20m

# Postgres (Supabase pooler)
DATABASE_URL=postgresql://postgres.<project_ref>:[YOUR-PASSWORD]@aws-1-<region>.pooler.supabase.com:6543/postgres

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_BASE_URL=http://localhost:3000

APP_PUBLIC_URL=http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:3001,https://www.malkiat.site,https://malkiat.site
BLOB_READ_WRITE_TOKEN=
# Optional: override cookie domain used when sharing auth cookies across subdomains.
# If unset, it is derived from APP_PUBLIC_URL in production-like environments.
# BETTER_AUTH_COOKIE_DOMAIN=.malkiat.site

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@realharis.works

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redis Stack (read model)
REDIS_URL=redis://default:[PASSWORD]@<host>:<port>

# Typesense (discovery/search)
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_ADMIN_API_KEY=
TYPESENSE_COLLECTION_LISTINGS=listings

# BullMQ Redis (queue)
# Can be the same as REDIS_URL, kept separate for flexibility
BULLMQ_REDIS_URL=redis://default:[PASSWORD]@<host>:<port>

# Listing events
LISTING_EVENTS_QUEUE_NAME=listing-events

# BullMQ Dashboard
BULLMQ_DASHBOARD_USER=admin
BULLMQ_DASHBOARD_PASSWORD=pass123
